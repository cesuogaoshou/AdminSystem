<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin.module.role.RoleMapper">

    <resultMap id="RoleResultMap" type="com.example.admin.module.role.Role">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="name" javaType="java.lang.String"/>
            <arg column="code" javaType="java.lang.String"/>
            <arg column="description" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.Integer"/>
            <arg column="sort_order" javaType="java.lang.Integer"/>
            <arg column="create_time" javaType="java.time.LocalDateTime"/>
            <arg column="update_time" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <resultMap id="RoleVOResultMap" type="com.example.admin.module.role.RoleVO">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="name" javaType="java.lang.String"/>
            <arg column="code" javaType="java.lang.String"/>
            <arg column="description" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.Integer"/>
            <arg column="sort_order" javaType="java.lang.Integer"/>
            <arg column="create_time" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="findById" resultMap="RoleResultMap">
        SELECT
            id, name, code, description, status, sort_order, create_time, update_time
        FROM sys_role
        WHERE id = #{id}
    </select>

    <select id="findByCode" resultMap="RoleResultMap">
        SELECT
            id, name, code, description, status, sort_order, create_time, update_time
        FROM sys_role
        WHERE code = #{code}
    </select>

    <select id="countByCode" resultType="int">
        SELECT COUNT(*)
        FROM sys_role
        WHERE code = #{code}
    </select>

    <insert id="insert">
        INSERT INTO sys_role (
            name, code, description, status, sort_order
        ) VALUES (
            #{name}, #{code}, #{description}, #{status}, #{sortOrder}
        )
    </insert>

    <update id="update">
        UPDATE sys_role
        SET
            name = #{name},
            code = #{code},
            description = #{description},
            status = #{status},
            sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_role
        WHERE id = #{id}
    </delete>

    <update id="updateStatus">
        UPDATE sys_role
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <select id="countUsersByRoleId" resultType="int">
        SELECT COUNT(*)
        FROM sys_user_role
        WHERE role_id = #{roleId}
    </select>

    <select id="findPage" resultMap="RoleVOResultMap">
        SELECT
            id, name, code, description, status, sort_order, create_time
        FROM sys_role
        WHERE 1 = 1
        <if test="name != null and name != ''">
            AND (name LIKE CONCAT('%', #{name}, '%')
                 OR code LIKE CONCAT('%', #{name}, '%'))
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY sort_order ASC, id ASC
    </select>

</mapper>
